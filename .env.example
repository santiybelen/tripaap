# Postgres connection string from Railway → Variables → DATABASE_URL
DATABASE_URL="postgresql://user:password@host:port/database"

# Auth.js secret. Generate with: openssl rand -base64 32
# In Railway, click "Generate" on this variable.
AUTH_SECRET="replace-me-with-a-random-string"

# In production this is set automatically. For local dev only.
AUTH_URL="http://localhost:3000"
